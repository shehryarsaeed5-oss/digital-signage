t 40%),linear-gradient(135deg,#304662 0%,#111827 52%,#05070b 100%);box-shadow:0 12px 22px rgba(0,0,0,.2)}.wall-preview-card.is-coming .wall-preview-poster:before{background:linear-gradient(180deg,rgba(252,200,43,.18),transparent 40%),linear-gradient(135deg,#49361b 0%,#20160b 52%,#05070b 100%)}.wall-preview-content{min-width:0;min-height:0;display:flex;flex-direction:column;justify-content:space-between;gap:calc(var(--w-header-gap) * var(--w-scale));padding:calc(var(--w-card-pad) * var(--w-scale));background:linear-gradient(90deg,#05070a 0%,#0d121a 100%)}.wall-preview-content-top{display:flex;flex-direction:column;gap:calc(var(--w-header-gap) * var(--w-scale));min-width:0}.wall-preview-status,.wall-preview-release-label{color:#fcc82b;font-size:calc(var(--w-status) * var(--w-scale));font-weight:800;letter-spacing:.18em;text-transform:uppercase;white-space:nowrap}.wall-preview-title{margin:0;color:#fff8ee;font-size:calc(var(--w-title) * var(--w-scale));line-height:1.02;font-weight:900;letter-spacing:.01em;text-transform:uppercase;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;text-shadow:0 4px 10px rgba(0,0,0,.46)}.wall-preview-runtime{color:#f6c671;font-size:calc((var(--w-status) * .94) * var(--w-scale));font-weight:700;letter-spacing:.16em;text-transform:uppercase}.wall-preview-times{display:flex;flex-wrap:wrap;gap:calc(10px * var(--w-scale));align-items:flex-start}.wall-preview-pill{min-height:calc(40px * var(--w-scale));padding:0 calc(16px * var(--w-scale));display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.12);border-radius:max(2px,var(--w-radius));background:rgba(255,255,255,.07);color:#fff;font-size:calc(var(--w-time) * var(--w-scale));font-weight:800;letter-spacing:.04em;white-space:nowrap}.wall-preview-pill.is-next{background:linear-gradient(135deg,#f6cb74,#f59e0b);color:#1a0f02;border-color:transparent;box-shadow:0 6px 14px rgba(245,158,11,.2)}.wall-preview-release{display:flex;flex-direction:column;gap:calc(10px * var(--w-scale))}.wall-preview-release-date{color:#fff;font-size:calc((var(--w-title) * .9) * var(--w-scale));font-weight:800;line-height:1.02;text-transform:uppercase}.wall-controls-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px 18px}.wall-actions{display:flex;justify-content:flex-end;gap:12px;margin-top:8px}.wall-field{align-content:start}.wall-field-heading{display:flex;align-items:center;gap:8px;min-width:0}.wall-field-heading>span:first-child{line-height:1.35}.field-help{position:relative;display:inline-flex;align-items:center}.field-help-button{width:20px;height:20px;padding:0;display:inline-flex;align-items:center;justify-content:center;border:1px solid #cbd5e1;border-radius:999px;background:#f8fafc;color:#475569;font-size:12px;font-weight:800;line-height:1;cursor:help;transition:border-color .16s ease,background .16s ease,color .16s ease,box-shadow .16s ease}.field-help-button:hover,.field-help-button:focus-visible{border-color:#94a3b8;background:#fff;color:#0f172a;box-shadow:0 0 0 3px rgba(148,163,184,.16);outline:none}.field-help-tooltip{position:absolute;left:0;bottom:calc(100% + 10px);z-index:8;width:min(240px,calc(100vw - 48px));padding:10px 12px;border-radius:10px;background:rgba(15,23,42,.96);color:#e2e8f0;font-size:12px;font-weight:500;line-height:1.45;letter-spacing:0;box-shadow:0 14px 30px rgba(15,23,42,.2);opacity:0;visibility:hidden;transform:translateY(4px);transition:opacity .16s ease,transform .16s ease,visibility .16s ease;pointer-events:none}.field-help-tooltip:after{content:"";position:absolute;left:10px;top:100%;border-width:6px 6px 0 6px;border-style:solid;border-color:rgba(15,23,42,.96) transparent transparent transparent}.field-help:hover .field-help-tooltip,.field-help:focus-within .field-help-tooltip{opacity:1;visibility:visible;transform:translateY(0)}.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

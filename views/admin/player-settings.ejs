</style>

<main class="admin-grid">
  <section class="panel panel-wide" id="screen-player-settings-card">
    <div class="panel-heading">
      <div>
        <h2>Screen-Specific Settings</h2>
        <p class="muted">Pick a screen, load its saved playback settings, and save a dedicated record for that player.</p>
      </div>
    </div>

    <form id="screen-player-settings-form" class="stack">
      <label>
        <span>Select Screen</span>
        <select id="player-settings-screen" name="screen">
          <option value="signage">Signage Player</option>
          <option value="cinema">Cinema Player</option>
          <option value="cinema-portrait">Cinema Portrait Player</option>
          <option value="cinema-3x2">Cinema 3x2 Player</option>
        </select>
      </label>

      <div class="screen-settings-grid">
        <label>
          <span>Now Showing Duration (seconds)</span>
          <input type="number" name="now_showing_duration_seconds" min="1" max="60" step="1" value="<%= settings.now_showing_duration_seconds %>" required>
        </label>
        <label>
          <span>Coming Soon Duration (seconds)</span>
          <input type="number" name="coming_soon_duration_seconds" min="1" max="60" step="1" value="<%= settings.coming_soon_duration_seconds %>" required>
        </label>
        <label class="checkbox-field">
          <span>Enable Ads</span>
          <input type="checkbox" name="enable_ads" <%= settings.enable_ads ? 'checked' : '' %>>
        </label>
        <label>
          <span>Ad Frequency (movies)</span>
          <input type="number" name="ad_frequency_movies" min="1" max="10" step="1" value="<%= settings.ad_frequency_movies %>" required>
        </label>
      </div>

      <div class="form-actions">
        <button type="submit">Save Screen Settings</button>
        <button type="button" class="secondary" id="screen-settings-reset-button">Reset Form</button>
      </div>
    </form>
  </section>

  <section class="panel panel-wide">
    <div class="panel-heading">
      <div>
        <h2>Saved Screen Settings</h2>
        <p class="muted">Existing screen records appear here. Use Edit to load a record back into the form.</p>
      </div>
    </div>

    <div class="screen-settings-table-shell">
      <div class="screen-settings-state" id="screen-settings-loading">Loading saved screen settings…</div>
      <div class="screen-settings-state alert error hidden" id="screen-settings-error"></div>
      <p class="empty-state hidden" id="screen-settings-empty">No screen settings saved yet.</p>
      <div class="screen-settings-table-wrapper">
        <table class="screen-settings-table" aria-live="polite">
          <thead>
            <tr>
              <th>Screen</th>
              <th>Now Showing Duration</th>
              <th>Coming Soon Duration</th>
              <th>Enable Ads</th>
              <th>Ads Frequency</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="screen-settings-table-body"></tbody>
        </table>
      </div>
    </div>

    <template id="screen-settings-row-template">
      <tr>
        <td data-field="screen"></td>
        <td data-field="now_showing_duration_seconds"></td>
        <td data-field="coming_soon_duration_seconds"></td>
        <td data-field="enable_ads"></td>
        <td data-field="ad_frequency_movies"></td>
        <td>
          <button type="button" class="screen-settings-action-button is-neutral" data-screen="">Edit</button>
        </td>
      </tr>
    </template>
  </section>

  <section class="panel panel-wide">
    <div class="panel-heading">
      <div>
        <h2>Playback Configuration</h2>
        <p class="muted">Set the shared playback timings for movies and configure how ads are inserted into the rotation.</p>
      </div>
    </div>
    <% if (success) { %><div class="alert success"><%= success %></div><% } %>
    <% if (error) { %><div class="alert error"><%= error %></div><% } %>
    <form method="post" action="/admin/player-settings" class="stack">
      <label><span>Now Showing poster duration (seconds)</span><input type="number" name="now_showing_duration_seconds" min="1" max="60" step="1" value="<%= settings.now_showing_duration_seconds %>" required></label>
      <label><span>Coming Soon poster duration (seconds)</span><input type="number" name="coming_soon_duration_seconds" min="1" max="60" step="1" value="<%= settings.coming_soon_duration_seconds %>" required></label>
      <label class="checkbox-field"><span>Enable Ads</span><input type="checkbox" name="enable_ads" <%= settings.enable_ads ? 'checked' : '' %>></label>
      <label><span>Play an ad after every X movies</span><input type="number" name="ad_frequency_movies" min="1" max="10" step="1" value="<%= settings.ad_frequency_movies %>" required></label>
      <div class="panel-heading" style="padding:0;margin-top:6px;">
        <div>
          <h2 style="font-size:18px;">Screen Ad Visibility</h2>
          <p class="muted">Control ad visibility independently for each player screen.</p>
        </div>
      </div>
      <label class="checkbox-field"><span>Signage Player · Show Ads: <strong><%= settings.player_ads_enabled ? 'ON' : 'OFF' %></strong></span><input type="checkbox" name="player_ads_enabled" <%= settings.player_ads_enabled ? 'checked' : '' %>></label>
      <label class="checkbox-field"><span>Cinema Player · Show Ads: <strong><%= settings.cinema_ads_enabled ? 'ON' : 'OFF' %></strong></span><input type="checkbox" name="cinema_ads_enabled" <%= settings.cinema_ads_enabled ? 'checked' : '' %>></label>
      <label class="checkbox-field"><span>Cinema Portrait Player · Show Ads: <strong><%= settings.cinema_portrait_ads_enabled ? 'ON' : 'OFF' %></strong></span><input type="checkbox" name="cinema_portrait_ads_enabled" <%= settings.cinema_portrait_ads_enabled ? 'checked' : '' %>></label>
      <label class="checkbox-field"><span>Cinema 3x2 Player · Show Ads: <strong><%= settings.cinema_3x2_ads_enabled ? 'ON' : 'OFF' %></strong></span><input type="checkbox" name="cinema_3x2_ads_enabled" <%= settings.cinema_3x2_ads_enabled ? 'checked' : '' %>></label>
      <div class="form-actions"><button type="submit">Save General Settings</button></div>
    </form>
  </section>

  <section class="panel panel-wide appearance-editor-panel">
    <div class="panel-heading"><div><h2>Cinema Portrait Appearance</h2><p class="muted">Live editor for the vertical portrait player. Changes below update the preview instantly.</p></div></div>
    <div class="appearance-editor-container">
      <div class="appearance-editor-controls">
        <form id="portrait-settings-form" method="post" action="/admin/player-settings" class="stack">
          <div class="settings-grid">
            <label><span>Bottom strip height (VH)</span><input type="number" name="portrait_strip_height_vh" data-var="--p-strip-height" data-unit="vh" min="1" max="50" step="0.05" value="<%= p_strip %>"></label>
            <label><span>Movie title size (VH)</span><input type="number" name="portrait_title_font_size_vh" data-var="--p-title-size" data-unit="vh" min="0.5" max="10" step="0.05" value="<%= p_title %>"></label>
            <label><span>Status label size (VH)</span><input type="number" name="portrait_status_font_size_vh" data-var="--p-status-size" data-unit="vh" min="0.5" max="10" step="0.05" value="<%= p_status %>"></label>
            <label><span>Title / showtime gap (VH)</span><input type="number" name="portrait_gap_vh" data-var="--p-gap" data-unit="vh" min="0" max="5" step="0.05" value="<%= p_gap %>"></label>
            <label><span>Showtime chip height (VH)</span><input type="number" name="portrait_showtime_height_vh" data-var="--p-chip-height" data-unit="vh" min="1" max="10" step="0.05" value="<%= p_chip %>"></label>
            <label><span>Left badge width (%)</span><input type="number" name="portrait_badge_width_percent" data-var="--p-badge-width" data-unit="%" min="10" max="40" step="0.1" value="<%= p_badge %>"></label>
            <label><span>Info strip padding (VH)</span><input type="number" name="portrait_info_padding_vh" data-var="--p-padding" data-unit="vh" min="0" max="10" step="0.05" value="<%= p_padding %>"></label>
          </div>
          <input type="hidden" name="now_showing_duration_seconds" value="<%= settings.now_showing_duration_seconds %>">
          <input type="hidden" name="coming_soon_duration_seconds" value="<%= settings.coming_soon_duration_seconds %>">
          <input type="hidden" name="enable_ads" value="<%= settings.enable_ads ? 'on' : 'off' %>">
          <input type="hidden" name="ad_frequency_movies" value="<%= settings.ad_frequency_movies %>">
          <input type="hidden" name="player_ads_enabled" value="<%= settings.player_ads_enabled ? 'on' : '' %>">
          <input type="hidden" name="cinema_ads_enabled" value="<%= settings.cinema_ads_enabled ? 'on' : '' %>">
          <input type="hidden" name="cinema_portrait_ads_enabled" value="<%= settings.cinema_portrait_ads_enabled ? 'on' : '' %>">
          <input type="hidden" name="cinema_3x2_ads_enabled" value="<%= settings.cinema_3x2_ads_enabled ? 'on' : '' %>">
          <div class="form-actions" style="margin-top:12px;display:flex;gap:12px;">
            <button type="submit">Save Appearance</button>
            <button type="button" onclick="document.getElementById('reset-portrait-form').submit()" class="secondary" style="border-color:#dc2626;color:#dc2626;">Reset To Default</button>
          </div>
        </form>
      </div>
      <div class="appearance-preview-panel">
        <p class="preview-caption muted">LCD Monitor Preview (9:16)</p>
        <div class="lcd-frame">
          <div id="live-preview-window" class="preview-window">
            <div class="preview-poster-area">
              <img src="/uploads_test/movies/the-super-mario-galaxy-movie-a82d9d9a3c.jpg" class="preview-poster-mock" alt="" onerror="this.style.opacity=0">
              <div class="preview-poster-overlay"></div>
              <div style="position:absolute;color:rgba(255,255,255,.3);font-weight:900;font-size:10px;letter-spacing:.2em;">POSTER AREA</div>
            </div>
            <div class="preview-strip">
              <div class="preview-badge"><div class="preview-badge-content"><span class="preview-status-line">NOW</span><span class="preview-status-line">SHOWING</span></div></div>
              <div class="preview-info"><div class="preview-title">THE SUPER MARIO GALAXY MOVIE</div><div class="preview-showtimes"><span class="preview-chip is-next"><span class="preview-chip-badge">NEXT</span>04:00 PM</span><span class="preview-chip">07:15 PM</span></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <form id="reset-portrait-form" method="post" action="/admin/player-settings/reset-portrait" style="display:none;"></form>
  </section>

  <section class="panel panel-wide appearance-editor-panel">
    <div class="panel-heading"><div><h2>Cinema 3x3 Wall Appearance</h2><p class="muted">Global appearance controls for <code>/player/cinema</code>. The preview updates live and simulates a real 3x3 LCD wall with bezel gaps.</p></div></div>
    <div class="wall-preview-editor">
      <div class="wall-preview-header">
        <p class="preview-caption muted">3x3 Cinema Wall Preview</p>
        <div class="wall-preview-shell">
          <div class="wall-preview-frame">
            <div id="cinema-wall-live-preview" class="wall-preview">
            <% const wallCards = [
              { status: 'Now Showing', title: 'Thunder Run', runtime: '2h 05m', times: ['04:00 PM', '07:15 PM'] },
              { status: 'Now Showing', title: 'The Last Horizon', runtime: '1h 48m', times: ['05:30 PM', '08:40 PM'] },
              { status: 'Now Showing', title: 'Galaxy Streets', runtime: '2h 11m', times: ['06:10 PM', '09:20 PM'] },
              { status: 'Now Showing', title: 'Desert Echo', runtime: '1h 56m', times: ['03:45 PM', '06:55 PM'] },
              { status: 'Now Showing', title: 'Crimson Orbit', runtime: '2h 22m', times: ['07:00 PM', '10:05 PM'] },
              { status: 'Coming Soon', title: 'Kingdom Of Glass', release: '25 Apr 2026' },
              { status: 'Now Showing', title: 'Night Frequency', runtime: '1h 52m', times: ['04:35 PM', '08:00 PM'] },
              { status: 'Coming Soon', title: 'Neon Frontier', release: '01 May 2026' },
              { status: 'Coming Soon', title: 'Midnight Regent', release: '08 May 2026' },
            ]; %>
            <% wallCards.forEach((card) => { const isComing = card.status === 'Coming Soon'; %>
              <div class="wall-preview-screen">
                <div class="wall-preview-panel">
                  <article class="wall-preview-card <%= isComing ? 'is-coming' : '' %>">
                    <div class="wall-preview-poster"></div>
                    <div class="wall-preview-content">
                      <div class="wall-preview-content-top">
                        <span class="wall-preview-status"><%= card.status %></span>
                        <h3 class="wall-preview-title"><%= card.title %></h3>
                        <% if (!isComing) { %><span class="wall-preview-runtime"><%= card.runtime %></span><% } %>
                      </div>
                      <% if (isComing) { %>
                        <div class="wall-preview-release"><span class="wall-preview-release-label">Releasing</span><div class="wall-preview-release-date"><%= card.release %></div></div>
                      <% } else { %>
                        <div class="wall-preview-times">
                          <% card.times.forEach((time, index) => { %><span class="wall-preview-pill <%= index === 0 ? 'is-next' : '' %>"><%= time %></span><% }); %>
                        </div>
                      <% } %>
                    </div>
                  </article>
                </div>
              </div>
            <% }); %>
            </div>
          </div>
        </div>
      </div>

      <form id="cinema-wall-settings-form" method="post" action="/admin/player-settings" class="stack">
        <div class="wall-controls-grid">
          <label class="wall-field"><span class="wall-field-heading"><span>Grid gap / bezel spacing (px)</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does grid gap or bezel spacing control?" aria-describedby="cinema-wall-help-gap"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-gap" class="field-help-tooltip" role="tooltip">Controls the visible spacing between the 9 LCD tiles.</span></span></span><input type="number" name="cinema_wall_gap_px" data-var="--w-gap" data-unit="px" min="0" max="100" step="1" value="<%= w_gap %>"></label>
          <label class="wall-field"><span class="wall-field-heading"><span>Outer wall padding (px)</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does outer wall padding control?" aria-describedby="cinema-wall-help-padding"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-padding" class="field-help-tooltip" role="tooltip">Controls the empty space around the full 3x3 wall preview.</span></span></span><input type="number" name="cinema_wall_padding_px" data-var="--w-pad" data-unit="px" min="0" max="140" step="1" value="<%= w_padding %>"></label>
          <label class="wall-field"><span class="wall-field-heading"><span>Movie title font size (rem)</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does movie title font size control?" aria-describedby="cinema-wall-help-title"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-title" class="field-help-tooltip" role="tooltip">Controls the title size shown inside each wall tile.</span></span></span><input type="number" name="cinema_wall_title_font_rem" data-var="--w-title" data-unit="rem" min="0.8" max="4" step="0.05" value="<%= w_title %>"></label>
          <label class="wall-field"><span class="wall-field-heading"><span>Showtime font size (rem)</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does showtime font size control?" aria-describedby="cinema-wall-help-showtime"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-showtime" class="field-help-tooltip" role="tooltip">Controls the size of the showtime text inside each tile.</span></span></span><input type="number" name="cinema_wall_showtime_font_rem" data-var="--w-time" data-unit="rem" min="0.7" max="3" step="0.05" value="<%= w_showtime %>"></label>
          <label class="wall-field"><span class="wall-field-heading"><span>Status label font size (rem)</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does status label font size control?" aria-describedby="cinema-wall-help-status"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-status" class="field-help-tooltip" role="tooltip">Controls the size of labels like Now Showing and Coming Soon.</span></span></span><input type="number" name="cinema_wall_status_font_rem" data-var="--w-status" data-unit="rem" min="0.6" max="3" step="0.05" value="<%= w_status %>"></label>
          <label class="wall-field"><span class="wall-field-heading"><span>Card / content inner padding (px)</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does card or content inner padding control?" aria-describedby="cinema-wall-help-card-padding"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-card-padding" class="field-help-tooltip" role="tooltip">Controls the internal spacing around content inside each movie tile.</span></span></span><input type="number" name="cinema_wall_card_padding_px" data-var="--w-card-pad" data-unit="px" min="0" max="120" step="1" value="<%= w_card_padding %>"></label>
          <label class="wall-field"><span class="wall-field-heading"><span>Poster width ratio (%)</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does poster width ratio control?" aria-describedby="cinema-wall-help-poster-width"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-poster-width" class="field-help-tooltip" role="tooltip">Controls how much horizontal space the poster takes inside each tile.</span></span></span><input type="number" name="cinema_wall_poster_width_percent" data-var="--w-poster-width" data-unit="%" min="20" max="60" step="1" value="<%= w_poster_width %>"></label>
          <label class="wall-field"><span class="wall-field-heading"><span>Border radius / tile sharpness (px)</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does border radius or tile sharpness control?" aria-describedby="cinema-wall-help-radius"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-radius" class="field-help-tooltip" role="tooltip">Controls whether each tile corner looks sharper or more rounded.</span></span></span><input type="number" name="cinema_wall_radius_px" data-var="--w-radius" data-unit="px" min="0" max="40" step="1" value="<%= w_radius %>"></label>
          <label class="wall-field"><span class="wall-field-heading"><span>Header / top spacing (px)</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does header or top spacing control?" aria-describedby="cinema-wall-help-header-gap"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-header-gap" class="field-help-tooltip" role="tooltip">Controls the top spacing used between status, title, and other upper content.</span></span></span><input type="number" name="cinema_wall_header_gap_px" data-var="--w-header-gap" data-unit="px" min="0" max="60" step="1" value="<%= w_header_gap %>"></label>
          <label class="wall-field"><span class="wall-field-heading"><span>General content scale</span><span class="field-help"><button type="button" class="field-help-button" aria-label="What does general content scale control?" aria-describedby="cinema-wall-help-scale"><span aria-hidden="true">i</span></button><span id="cinema-wall-help-scale" class="field-help-tooltip" role="tooltip">Scales the content inside each tile up or down overall.</span></span></span><input type="number" name="cinema_wall_content_scale" data-var="--w-scale" data-unit="" min="0.6" max="1.6" step="0.05" value="<%= w_scale %>"></label>
        </div>

        <input type="hidden" name="now_showing_duration_seconds" value="<%= settings.now_showing_duration_seconds %>">
        <input type="hidden" name="coming_soon_duration_seconds" value="<%= settings.coming_soon_duration_seconds %>">
        <input type="hidden" name="enable_ads" value="<%= settings.enable_ads ? 'on' : 'off' %>">
        <input type="hidden" name="ad_frequency_movies" value="<%= settings.ad_frequency_movies %>">
        <input type="hidden" name="player_ads_enabled" value="<%= settings.player_ads_enabled ? 'on' : '' %>">
        <input type="hidden" name="cinema_ads_enabled" value="<%= settings.cinema_ads_enabled ? 'on' : '' %>">
        <input type="hidden" name="cinema_portrait_ads_enabled" value="<%= settings.cinema_portrait_ads_enabled ? 'on' : '' %>">
        <input type="hidden" name="cinema_3x2_ads_enabled" value="<%= settings.cinema_3x2_ads_enabled ? 'on' : '' %>">

        <div class="wall-actions">
          <button type="submit">Save Appearance</button>
          <button type="button" onclick="document.getElementById('reset-cinema-wall-form').submit()" class="secondary" style="border-color:#dc2626;color:#dc2626;">Reset To Default</button>
        </div>
      </form>
    </div>
    <form id="reset-cinema-wall-form" method="post" action="/admin/player-settings/reset-cinema-wall" style="display:none;"></form>
  </section>
</main>

<script src="/js/admin-player-settings.js"></script>
<script>
(() => {
  const bindLivePreview = (formId, previewId) => {
    const form = document.getElementById(formId);
    const preview = document.getElementById(previewId);
    if (!form || !preview) return;
    const inputs = form.querySelectorAll('input[data-var]');
    const updatePreview = () => inputs.forEach((input) => {
      preview.style.setProperty(input.getAttribute('data-var'), `${input.value || 0}${input.getAttribute('data-unit') || ''}`);
    });
    form.addEventListener('input', updatePreview);
    updatePreview();
  };
  bindLivePreview('portrait-settings-form', 'live-preview-window');
  bindLivePreview('cinema-wall-settings-form', 'cinema-wall-live-preview');
})();
</script>
<%- include('partials/layout-end') %>

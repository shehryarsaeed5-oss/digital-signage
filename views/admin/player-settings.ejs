<%- include('partials/layout-start', { pageTitle: 'Player Settings' }) %>
<header class="page-header">
  <div class="page-header-copy">
    <h1>Player Settings</h1>
    <p class="muted">Configure playback timing and ad rotation independently for each player screen.</p>
  </div>
  <div class="page-header-actions">
    <form method="post" action="/admin/player-settings/refresh-all-screens" style="margin: 0;">
      <button type="submit" class="secondary">Refresh All Screens</button>
    </form>
  </div>
</header>

<%
const screenCards = [
  {
    screen: 'cinema',
    title: 'Cinema Player',
    settings: screenSettings.cinema || {},
  },
  {
    screen: 'cinema-3x2',
    title: 'Cinema Player 3x2',
    settings: screenSettings['cinema-3x2'] || {},
  },
  {
    screen: 'cinema-portrait',
    title: 'Cinema Portrait Player',
    settings: screenSettings['cinema-portrait'] || {},
  },
];

const valueFor = (settings, key, fallback) => (
  settings && settings[key] !== undefined ? settings[key] : fallback
);
%>

<style>
  .player-settings-cards{display:grid;grid-template-columns:1fr;gap:20px;align-items:start}
  .player-settings-card .screen-settings-grid{display:grid;gap:14px}
</style>

<main class="admin-grid">
  <% if (success) { %><div class="alert success"><%= success %></div><% } %>
  <% if (error) { %><div class="alert error"><%= error %></div><% } %>

  <section class="panel panel-wide">
    <div class="panel-heading">
      <div>
        <h2>Screen Playback Settings</h2>
        <p class="muted">Each card saves settings for one player only.</p>
      </div>
    </div>

    <div class="player-settings-cards">
      <% screenCards.forEach((card) => { %>
        <section class="panel player-settings-card">
          <div class="panel-heading">
            <div>
              <h2><%= card.title %></h2>
              <p class="muted">Playback timing and ad frequency for <%= card.title.toLowerCase() %>.</p>
            </div>
          </div>

          <form method="post" action="/admin/player-settings" class="stack">
            <input type="hidden" name="screen" value="<%= card.screen %>">

            <div class="screen-settings-grid">
              <label>
                <span>Now Showing Duration (seconds)</span>
                <input type="number" name="now_showing_duration_seconds" min="1" max="60" step="1" value="<%= valueFor(card.settings, 'now_showing_duration_seconds', 8) %>" required>
              </label>
              <label>
                <span>Coming Soon Duration (seconds)</span>
                <input type="number" name="coming_soon_duration_seconds" min="1" max="60" step="1" value="<%= valueFor(card.settings, 'coming_soon_duration_seconds', 5) %>" required>
              </label>
              <label class="checkbox-field">
                <span>Enable Ads</span>
                <input type="checkbox" name="enable_ads" <%= card.settings.enable_ads ? 'checked' : '' %>>
              </label>
              <label>
                <span>Ad Frequency (movies)</span>
                <input type="number" name="ad_frequency_movies" min="1" max="10" step="1" value="<%= valueFor(card.settings, 'ad_frequency_movies', 2) %>" required>
              </label>
              <label>
                <span>Ad Break Interval (seconds)</span>
                <input type="number" name="ad_break_interval_seconds" min="15" max="3600" step="1" value="<%= valueFor(card.settings, 'ad_break_interval_seconds', 240) %>" required>
              </label>
              <label>
                <span>Ads Per Break</span>
                <input type="number" name="ads_per_break" min="1" max="10" step="1" value="<%= valueFor(card.settings, 'ads_per_break', 2) %>" required>
              </label>
              <label>
                <span>Max Video Ad Seconds</span>
                <input type="number" name="max_video_ad_seconds" min="1" max="120" step="1" value="<%= valueFor(card.settings, 'max_video_ad_seconds', 15) %>" required>
              </label>
              <label>
                <span>Default Image Ad Seconds</span>
                <input type="number" name="default_image_ad_seconds" min="1" max="120" step="1" value="<%= valueFor(card.settings, 'default_image_ad_seconds', 10) %>" required>
              </label>
              <label class="checkbox-field">
                <span>House Ad Fallback</span>
                <input type="checkbox" name="house_ad_fallback_enabled" <%= valueFor(card.settings, 'house_ad_fallback_enabled', true) ? 'checked' : '' %>>
              </label>
              <% if (card.screen === 'cinema' || card.screen === 'cinema-3x2') { %>
                <label>
                  <span>Poster Width (%)</span>
                  <input type="number" name="poster_width_percent" min="20" max="70" step="1" value="<%= valueFor(card.settings, 'poster_width_percent', 38) %>" required>
                </label>
                <label>
                  <span>Grid Height (%)</span>
                  <input type="number" name="row_height_percent" min="70" max="130" step="1" value="<%= valueFor(card.settings, 'row_height_percent', 100) %>" required>
                </label>
              <% } %>
            </div>

            <div class="form-actions">
              <button type="submit">Save <%= card.title %></button>
            </div>
          </form>
        </section>
      <% }); %>
    </div>
  </section>
</main>

<%- include('partials/layout-end') %>

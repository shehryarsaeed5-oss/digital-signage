<%- include('partials/layout-start', { pageTitle: 'Player Settings' }) %>
<header class="page-header">
  <div class="page-header-copy">
    <h1>Player Settings</h1>
    <p class="muted">Control shared playback timings and tune the live appearance of the portrait player and the cinema 3x3 wall.</p>
  </div>
</header>

<script>
  window.__PLAYER_SETTINGS_DEFAULTS__ = {
    now_showing_duration_seconds: <%= settings.now_showing_duration_seconds %>,
    coming_soon_duration_seconds: <%= settings.coming_soon_duration_seconds %>,
    enable_ads: <%= settings.enable_ads ? 'true' : 'false' %>,
    ad_frequency_movies: <%= settings.ad_frequency_movies %>
  };
</script>

<%
const p_strip = settings.portrait_strip_height_vh !== undefined ? settings.portrait_strip_height_vh : 8.5;
const p_title = settings.portrait_title_font_size_vh !== undefined ? settings.portrait_title_font_size_vh : 2.1;
const p_status = settings.portrait_status_font_size_vh !== undefined ? settings.portrait_status_font_size_vh : 1.18;
const p_gap = settings.portrait_gap_vh !== undefined ? settings.portrait_gap_vh : 0.35;
const p_chip = settings.portrait_showtime_height_vh !== undefined ? settings.portrait_showtime_height_vh : 2.65;
const p_badge = settings.portrait_badge_width_percent !== undefined ? settings.portrait_badge_width_percent : 18.5;
const p_padding = settings.portrait_info_padding_vh !== undefined ? settings.portrait_info_padding_vh : 1.6;

const w_gap = settings.cinema_wall_gap_px !== undefined ? settings.cinema_wall_gap_px : 30;
const w_padding = settings.cinema_wall_padding_px !== undefined ? settings.cinema_wall_padding_px : 30;
const w_title = settings.cinema_wall_title_font_rem !== undefined ? settings.cinema_wall_title_font_rem : 2.2;
const w_showtime = settings.cinema_wall_showtime_font_rem !== undefined ? settings.cinema_wall_showtime_font_rem : 1.6;
const w_status = settings.cinema_wall_status_font_rem !== undefined ? settings.cinema_wall_status_font_rem : 1.2;
const w_card_padding = settings.cinema_wall_card_padding_px !== undefined ? settings.cinema_wall_card_padding_px : 40;
const w_poster_width = settings.cinema_wall_poster_width_percent !== undefined ? settings.cinema_wall_poster_width_percent : 38;
const w_radius = settings.cinema_wall_radius_px !== undefined ? settings.cinema_wall_radius_px : 0;
const w_header_gap = settings.cinema_wall_header_gap_px !== undefined ? settings.cinema_wall_header_gap_px : 16;
const w_scale = settings.cinema_wall_content_scale !== undefined ? settings.cinema_wall_content_scale : 1;
%>

<style>

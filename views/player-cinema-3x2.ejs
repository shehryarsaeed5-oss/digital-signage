<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cinema Video Wall 3x2</title>
  <link rel="stylesheet" href="/css/player-cinema-3x2.css">
</head>
<body>
  <main id="cinema-player-3x2" class="cinema-wall-3x2">
    <div class="cinema-runtime-hooks" aria-hidden="true">
      <span id="cinema-clock-3x2">--:--</span>
      <span id="cinema-status-3x2">Loading...</span>
    </div>

    <section class="wall-screen wall-screen-now">
      <div id="now-slot-3x2-1" class="wall-screen-body wall-slot"></div>
    </section>

    <section class="wall-screen wall-screen-now">
      <div id="now-slot-3x2-2" class="wall-screen-body wall-slot"></div>
    </section>

    <section class="wall-screen wall-screen-now">
      <div id="now-slot-3x2-3" class="wall-screen-body wall-slot"></div>
    </section>

    <section class="wall-screen wall-screen-now">
      <div id="now-slot-3x2-4" class="wall-screen-body wall-slot"></div>
    </section>

    <section class="wall-screen wall-screen-now">
      <div id="now-slot-3x2-5" class="wall-screen-body wall-slot"></div>
    </section>

    <section class="wall-screen wall-screen-now">
      <div id="now-slot-3x2-6" class="wall-screen-body wall-slot"></div>
    </section>
  </main>

  <script src="/js/player-cinema-3x2.js"></script>
</body>
</html>
